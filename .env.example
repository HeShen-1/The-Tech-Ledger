# ===== Data Sources =====

# Firecrawl — Web scraping API
# Sign up: https://firecrawl.dev
# Docs: https://docs.firecrawl.dev
FIRECRAWL_API_KEY=fc-xxx

# Tavily — AI search API
# Sign up: https://tavily.com
# Docs: https://docs.tavily.com
TAVILY_API_KEY=tvly-xxx

# Exa — Semantic search API
# Sign up: https://exa.ai
# Docs: https://docs.exa.ai
EXA_API_KEY=xxx

# ===== AI Summarization =====

# DeepSeek — LLM API
# Sign up: https://platform.deepseek.com
# Docs: https://api-docs.deepseek.com
# Model: deepseek-v4-flash
DEEPSEEK_API_KEY=sk-xxx

# ===== Infrastructure =====

# Vercel KV — Redis edge cache
# Auto-configured by Vercel when KV is connected
# Dashboard: https://vercel.com/dashboard/stores
KV_URL=redis://xxx
KV_REST_API_URL=https://xxx
KV_REST_API_TOKEN=xxx

# ===== Security =====

# Secret token for cache refresh + report snapshot triggers
REFRESH_TOKEN=change-me-to-random-string
